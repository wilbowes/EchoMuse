# EchoMuse Controller — environment variables
# Copy to .env and fill in values before starting
# ── Network ───────────────────────────────────────────────────────────────────
# Bind address — 0.0.0.0 to listen on all interfaces
SERVER_HOST=0.0.0.0
# WebSocket server port — devices connect here (/control, /data, /shell)
SERVER_PORT=8767
# HTTP API + dashboard port
API_PORT=8768
# IP address of this host on the LAN — advertised via mDNS
# Devices use this to connect; must be reachable from Echo Dots
SERVER_IP=10.x.y.z
# mDNS service name — advertised as {MDNS_NAME}._emcontroller._tcp.local
MDNS_NAME=echomuse
# ── Voice pipeline ────────────────────────────────────────────────────────────
# Voice backend mode — 'claracore' (default) or 'esphome'
# claracore: controller connects to ClaraCore voice server via WebSocket
# esphome:   controller exposes ESPHome native API listeners; HA drives voice
#            turns via Assist. Changing this requires a controller restart.
VOICE_MODE=claracore
# ClaraCore voice server URI — only used when VOICE_MODE=claracore
VOICE_WS_URI=ws://10.x.y.z:8765
# ESPHome project version string reported to HA in device info.
# Should match the controller release version tag.
# Only used when VOICE_MODE=esphome.
ESPHOME_PROJECT_VERSION=2.0.0
# ── Wake word ─────────────────────────────────────────────────────────────────
# OpenWakeWord model name (without _v0.1.onnx suffix)
OWW_MODEL=hey_jarvis
# Detection threshold — lower = more sensitive
# 0.3 works well for UK accents; default upstream is 0.5
OWW_THRESHOLD=0.3
# ── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite database file inside the container
# Mount ~/EchoMuse/controller/data:/app/data in docker-compose.yml
DB_PATH=/app/data/echomuse.db
# ── Device approval ───────────────────────────────────────────────────────────
# strict — unknown devices held in pending queue until admin approves (default)
# auto   — unknown devices approved immediately as "Unknown {serial[:8]}"
DEVICE_APPROVAL=strict
